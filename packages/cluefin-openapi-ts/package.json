{
  "name": "cluefin-openapi",
  "version": "0.1.0",
  "description": "TypeScript OpenAPI client for KIS and Kiwoom",
  "license": "MIT",
  "author": "kgcrom",
  "repository": {
    "type": "git",
    "url": "https://github.com/kgcrom/cluefin.git",
    "directory": "packages/cluefin-openapi-ts"
  },
  "keywords": [
    "korean-stock",
    "kiwoom",
    "kis",
    "openapi",
    "trading",
    "stock-market"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "generate:metadata": "node ./scripts/generate-metadata.mjs",
    "build:types": "node ./scripts/generate-types.mjs",
    "build:js": "tsup --config ./tsup.config.ts",
    "build": "npm run clean && npm run build:types && npm run build:js",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "check": "biome check .",
    "typecheck": "tsup --config ./tsup.config.ts --silent",
    "test:unit": "vitest run --config ./vitest.config.ts",
    "test:integration": "CLUEFIN_OPENAPI_TS_RUN_INTEGRATION=1 vitest run --config ./vitest.integration.config.ts",
    "test": "npm run test:unit",
    "publish:check": "npm run build && npm run check && npm run typecheck && npm run test",
    "publish:preview": "npm run publish:check && npm pack --dry-run",
    "publish:manual": "npm run publish:check && npm publish --access public"
  },
  "dependencies": {
    "ws": "^8.19.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@types/node": "^24.3.0",
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
